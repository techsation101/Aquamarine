{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Aquamarine",
	"scopeName": "source.aquamarine",
	"patterns": [
		{ "include": "#commands" },
		{ "include": "#variables" },
		{ "include": "#operators" },
		{ "include": "#numbers" },
		{ "include": "#strings" }
	],
	"repository": {
		"commands": {
			"patterns": [
				{
					"name": "keyword.control.aquamarine",
					"match": "\\b(p|f)(?=`)"
				},
				{
					"name": "keyword.control.aquamarine",
					"match": "`(m|f|t|i)\\b"
				},
				{
					"name": "keyword.control.aquamarine",
					"match": "\\bRETURN\\b"
				},
				{
					"name": "keyword.control.import.aquamarine",
					"match": "#\\+"
				},
				{
					"name": "punctuation.definition.function.aquamarine",
					"match": "@"
				}
			]
		},
		"variables": {
			"patterns": [
				{
					"name": "variable.other.reference.aquamarine",
					"match": "\\\\[a-zA-Z0-9_.]+\\\\"
				},
				{
					"name": "variable.name.aquamarine",
					"match": "[a-zA-Z0-9_.]+(?==)"
				}
			]
		},
		"strings": {
			"name": "string.quoted.backtick.aquamarine",
			"begin": "`",
			"end": "`",
			"patterns": [
				{ "include": "#variables" }
			]
		},
		"operators": {
			"patterns": [{
				"name": "keyword.operator.aquamarine",
				"match": "(\\+|-|\\*|/|%|\\^|=)"
			}]
		},
		"numbers": {
			"patterns": [{
				"name": "constant.numeric.aquamarine",
				"match": "\\b\\d+(\\.\\d+)?\\b"
			}]
		}
	}
}