{
  "name": "am",
  "displayName": "Aquamarine",
  "description": "A python-based programming language for me",
  "version": "0.0.1",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [{
      "id": "am",
      "aliases": ["Aquamarine", "am"],
      "extensions": [".am"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "am",
      "scopeName": "source.am",
      "path": "./syntaxes/am.tmLanguage.json"
    }],
    "iconThemes": [
        {
            "id": "aquamarine-icons",
            "label": "Aquamarine Icons",
            "path": "./aquamarine-icons.json"
        }
    ]
  }
}
